{
  "name": "auto-system",
  "version": "1.0.0",
  "description": "temu-auto",
  "homepage": "https://github.com/firemkyLTD/temu-auto-system#readme",
  "bugs": {
    "url": "https://github.com/firemkyLTD/temu-auto-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firemkyLTD/temu-auto-system.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist-electron/electron/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:electron": "tsc -p tsconfig.electron-main.json && tsc -p tsconfig.preload.json",
    "dev:electron": "npm run build:electron && wait-on http://localhost:5174 && electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:api": "node scripts/compliance-template-api.js",
    "start:api": "node scripts/compliance-template-api.js",
    "migrate:compliance-template": "node scripts/run-compliance-template-migration.js",
    "build": "npm run build:electron && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron-main.json && tsc --noEmit -p tsconfig.preload.json"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^43.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
